{
  "backbone_name": "EfficientNetB2",
  "optimizer": "adam",
  "head_lr": 0.001,
  "ft_lr": 1e-05,
  "weight_decay": 0.0,
  "dropout_rate": 0.6,
  "label_smoothing": 0.0,
  "batch_size": 16,
  "unfreeze_ratio": 1.0,
  "lr_schedule": "plateau",
  "epochs_phase1": 5,
  "epochs_phase2": 45,
  "target_sensitivity": 0.9,
  "use_memory_cache": false
}
