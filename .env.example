# Production API: browser calls https://api.chexit.app (see src/api/chexit.ts). Long /predict cannot use Vercel /api rewrites (proxy timeout).
# Override: VITE_CHEXIT_API_URL=https://your-api.example (no /predict). Local: leave empty — npm run dev proxies /api → :8000.
# VITE_CHEXIT_API_URL=
# VITE_USE_RELATIVE_API=1   # force same-origin /api (OK for local; on Vercel, long predict may still 504)

# --- Chexit API (Render / local uvicorn) — U-Net from Google Drive via gdown if files missing ---
# CHEXIT_SKIP_GDOWN=1
# CHEXIT_GDOWN_UNET_BEST_ID=
# CHEXIT_GDOWN_ALL_UNET=1
# CHEXIT_GDOWN_UNET_WEIGHTS_ID=
# CHEXIT_GDOWN_UNET_FINAL_ID=
# CHEXIT_ASSETS_ROOT=
# Holdout checkpoints (final split): place *_{holdout}_*.weights.h5 under assets/*/weights/ or:
# CHEXIT_HOLDOUT_WEIGHTS_DIR=/absolute/path/to/weights
# CHEXIT_DENSENET_WEIGHTS=/absolute/path/to/dense_holdout_best.weights.h5
# CHEXIT_MOBILENET_WEIGHTS=/absolute/path/to/mob_holdout_best.weights.h5
# CHEXIT_EFFICIENTNET_WEIGHTS=/absolute/path/to/eff_holdout_best.weights.h5
# CHEXIT_UPLOADS_DIR=/var/chexit/uploads
# CHEXIT_META_LEARNER_PATH=/absolute/path/to/meta_learner.joblib
# CHEXIT_META_THRESHOLD_PATH=/absolute/path/to/ensemble_threshold.json
# CHEXIT_SKIP_SCORECAM=1
# CHEXIT_MAX_CXR_EDGE=2048
